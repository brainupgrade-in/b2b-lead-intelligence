{
  "name": "b2b-lead-intelligence",
  "version": "1.0.0",
  "description": "ICP-driven B2B lead intelligence: source matching companies from public directories, enrich with contacts / tech stack / decision-makers / intent signals, and rank by ICP fit.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run start:dev",
    "start:prod": "node dist/main.js",
    "start:dev": "tsx src/main.ts",
    "build": "tsc",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json"
  },
  "keywords": [
    "apify",
    "actor",
    "lead-generation",
    "web-scraping",
    "company-data",
    "tech-stack",
    "contact-extraction",
    "b2b",
    "sales-intelligence"
  ],
  "author": "Rajesh",
  "license": "ISC",
  "homepage": "https://apify.com/ghewaretech/b2b-lead-intelligence",
  "repository": {
    "type": "git",
    "url": "https://github.com/brainupgrade-in/b2b-lead-intelligence"
  },
  "dependencies": {
    "apify": "^3.2.0",
    "crawlee": "^3.11.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@apify/tsconfig": "^0.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
